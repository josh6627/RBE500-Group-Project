<?xml version="1.0"?>
<robot name="arm">

  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.9 1"/>
  </material>

  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.16 1.08"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.16 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="1.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <joint name="joint1_2" type="fixed">
    <parent link="link1"/>
    <child link="link_1_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

   <link name="link_1_2">
    <visual>
      <origin xyz="0.46 0 1.0" rpy="0 0 0"/>
      <geometry>
        <box size="1.08 0.16 0.16"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.46 0 1.0" rpy="0 0 0"/>
      <geometry>
        <box size="1.08 0.16 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.46 0 1.0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link_1_2"/>
    <child link="link_joint2"/>
    <origin xyz="1 0 1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1"/>
  </joint>

  <link name="link_joint2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.16"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <joint name="joint2_2" type="fixed">
    <parent link="link_joint2"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0.54 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.08 0.16 0.16"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.54 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.08 0.16 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.54 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
    </inertial>
  </link>

   <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="1 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>

    <limit
      lower="0"
      upper="0.5"
      effort="100"
      velocity="0"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.16 0.66"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.16 0.16 0.66"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <mass value="1.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <gazebo reference="link3">
    <gravity>false</gravity>
    <kinematic>true</kinematic>
  </gazebo>

  <!-- <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo> -->

  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so"
            name="gazebo_ros2_control">
    </plugin>
  </gazebo>

</robot>