<?xml version="1.0"?>
<robot name="arm">
  <!--
    Launching gazebo:
        ros2 launch ros_gz_sim gz_sim.launch.py gz_args:=empty.sdf

    Spawning robot: (change file path)
        ros2 launch ros_gz_sim gz_spawn_model.launch.py   world:=empty   file:=$HOME/Robotics/rbe500/group-project/src/scara_params/urdf/scara.urdf   entity_name:=arm   x:=0.0 y:=0.0 z:=0.0

  -->

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>

  <material name="blue">
    <color rgba="0.1 0.3 0.9 1"/>
  </material>

  <!-- Fixed base because each joint neads to links to be created -->
  <link name="base">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Revolute joint -->
  <joint name="joint_1" type="revolute">
    <parent link="base"/>
    <child link="link_1"/>

    <!-- Put the joint on top of the base -->
    <origin xyz="0 0 0" rpy="0 0 0"/>

    <!-- Rotate around vertical z-axis -->
    <axis xyz="0 0 1"/>

    <limit lower="-3.14" upper="3.14" effort="20" velocity="1"/>
  </joint>

  <!-- L-shaped Link 1 -->
<link name="link_1">

  <!-- vertical part -->
  <visual>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <geometry>
      <box size="0.08 0.08 1.0"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <geometry>
      <box size="0.08 0.08 1.0"/>
    </geometry>
  </collision>

  <!-- horizontal part -->
  <visual>
    <origin xyz="0.5 0 1.0" rpy="0 0 0"/>
    <geometry>
      <box size="1.0 0.08 0.08"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <origin xyz="0.5 0 1.0" rpy="0 0 0"/>
    <geometry>
      <box size="1.0 0.08 0.08"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="0.25 0 0.75" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
  </inertial>

</link>

<!-- Joint 2 at the end of the L-shaped link -->
<joint name="joint_2" type="revolute">
  <parent link="link_1"/>
  <child link="link_2"/>
  <origin xyz="1.0 0 1.0" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-3.14" upper="3.14" effort="20" velocity="1"/>
</joint>

<!-- Link 2 extends out from joint_2 -->
<link name="link_2">

  <!-- Small visible joint hub at joint_2 -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.08"/>
    </geometry>
    <material name="gray"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.08"/>
    </geometry>
  </collision>

  <visual>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="1.0 0.08 0.08"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="1.0 0.08 0.08"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
  </inertial>
</link>

  <!-- Joint 3: final prismatic joint -->
  <joint name="joint_3" type="prismatic">
    <parent link="link_2"/>
    <child link="tool_link"/>

    <!-- joint_3 is at the end of link_2 -->
    <origin xyz="1.0 0 0" rpy="0 0 0"/>

    <!-- Positive joint_3 moves downward -->
    <axis xyz="0 0 -1"/>

    <limit lower="0.0" upper="0.5" effort="20" velocity="0.25"/>
  </joint>

  <!-- End effector / sliding tool -->
  <link name="tool_link">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <!-- Publish joint values from Gazebo -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>joint_1</joint_name>
      <joint_name>joint_2</joint_name>
    </plugin>
  </gazebo>

</robot>